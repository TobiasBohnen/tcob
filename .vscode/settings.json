{
    "C_Cpp.clang_format_sortIncludes": true,
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.intelliSenseMode": "windows-msvc-x64",
    "testMate.cpp.test.workingDirectory": "${workspaceFolder}/build/x64",
    "testMate.cpp.test.advancedExecutables": [
        {
            "pattern": "{build,Build,BUILD,out,Out,OUT}/{debug,Debug,DEBUG}/**/*{tests,Tests,TESTS}*",
            "catch2": {
                "testGrouping": {
                    "groupByExecutable": {
                        "label": "${relDirpath}",
                        "groupByRegex": {
                            "regexes": [
                                "^([^.]+)"
                            ],
                            "label": "${match}",
                            "groupByRegex": {
                                "regexes": [
                                    "^([^.]+.[^.]+)"
                                ],
                                "label": "${match}"
                            }
                        }
                    }
                }
            }
        }
    ],
    "cmake.debugConfig": {
        "cwd": "${workspaceFolder}/build/x64",
        "console": "newExternalWindow",
        "type": "cppvsdbg"
    },
    "cmake.buildDirectory": "${workspaceFolder}/build/${buildType}",
